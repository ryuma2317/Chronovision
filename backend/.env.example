# Server
PORT=3001
NODE_ENV=development

# ============================================================
# Database — Supabase (PostgreSQL)
# Find these in Supabase: Project → Connect → "Session pooler"
# (or "Direct connection"). Use port 5432, NOT the 6543 transaction
# pooler — this app uses SQL transactions that need a session.
# ============================================================
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.<your-project-ref>
DB_PASSWORD=<your-database-password>
DB_SSL=true

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Flask ML microservice
FLASK_ML_URL=http://localhost:5001

# Anthropic API key — used by quiz.service.js to generate MCQ questions
# from uploaded docx/pdf lesson material. Leave blank to disable AI quiz
# generation (manual quiz creation still works without it).
ANTHROPIC_API_KEY=

# File uploads
UPLOAD_DIR=./uploads
