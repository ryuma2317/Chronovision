# Server
PORT=3001
NODE_ENV=development

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=chronovision
DB_USER=chronovision_app
DB_PASSWORD=

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRES_IN=7d

# Flask ML microservice
FLASK_ML_URL=http://localhost:5001

# Anthropic API key — used by quiz.service.js to generate MCQ questions
# from uploaded docx/pdf lesson material. Leave blank to disable AI quiz
# generation (manual quiz creation still works without it).
ANTHROPIC_API_KEY=

# File uploads
UPLOAD_DIR=./uploads
